# Supabase Configuration
# Get these from your Supabase project Settings > API

# Your Supabase project URL
# Example: https://your-project-id.supabase.co
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon public key
# Go to Settings > API and copy the "anon public" key
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service role key (only for admin operations)
# WARNING: Never expose this in client-side code
# VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application Configuration
# Vite will automatically prefix with VITE_ when exposed to the client
NODE_ENV=development

# Wix Integration - Webhook Receiver
# Secret token for verifying Wix webhook requests
# Generate a secure random token (e.g., using: openssl rand -hex 32)
# This must match what you configure in your Wix app
WIX_WEBHOOK_SECRET=your-wix-webhook-secret-here

# Wix Integration - Event Import
# Required only for bulk importing existing events from Wix
# Get these from https://dev.wix.com
WIX_API_KEY=your-wix-api-key-here
WIX_SITE_ID=your-wix-site-id-here

# Supabase Service Role Key
# WARNING: This is a sensitive credential with admin access
# Only use locally or in secure backend environments
# Get from Supabase Dashboard → Settings → API → Service Role (Secret)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Wix Integration - Blog Publishing
# API token for publishing blog posts to your Wix site
# Get from Wix Developer → API & Extensions → API Keys
VITE_WIX_API_TOKEN=your-wix-api-token-here

# Instagram Graph API Integration
# Get these from Meta Business Platform (developers.facebook.com)
VITE_INSTAGRAM_CLIENT_ID=your-instagram-client-id
VITE_INSTAGRAM_CLIENT_SECRET=your-instagram-client-secret
VITE_INSTAGRAM_REDIRECT_URI=http://localhost:5173/instagram-callback
VITE_INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your-instagram-webhook-verify-token

# Instagram Webhook (for Edge Functions)
# Set in Supabase → Edge Functions → instagram-webhook environment
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your-instagram-webhook-verify-token
