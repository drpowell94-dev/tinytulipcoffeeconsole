# Supabase Configuration
# Get these from your Supabase project Settings > API

# Your Supabase project URL
# Example: https://your-project-id.supabase.co
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase anon public key
# Go to Settings > API and copy the "anon public" key
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Service role key (only for admin operations)
# WARNING: Never expose this in client-side code
# VITE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Application Configuration
# Vite will automatically prefix with VITE_ when exposed to the client
NODE_ENV=development
